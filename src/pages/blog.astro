---
import '../styles/globals.css';
import '@fontsource-variable/geist';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Blog | rockyxwall";
const description = "Sharing my journey and learnings as a tech hobbyist and student.";

const posts = [
  {
    title: "Starting my journey as a Tech Hobbyist",
    excerpt: "Why I decided to dive into web development and what I hope to achieve.",
    date: "2024-04-01",
    readingTime: "5 min"
  },
  {
    title: "How I built my personal study site",
    excerpt: "A deep dive into the creation of lazy-study-doc.",
    date: "2024-03-20",
    readingTime: "10 min"
  },
  {
    title: "My favorite VS Code extensions for 2024",
    excerpt: "Tools that help me stay productive as a student.",
    date: "2024-02-15",
    readingTime: "7 min"
  }
];

---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <meta name="description" content={description} />
	</head>

	<body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 container max-w-screen-md mx-auto px-4 py-12 md:py-24 space-y-12">
      <section class="space-y-4">
        <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
        <p class="text-foreground/60 leading-relaxed">
          Sharing my thoughts on building products, engineering challenges, and the journey of an indie hacker.
        </p>
      </section>

      <section class="space-y-8">
        {posts.map((post) => (
          <article class="group relative flex flex-col space-y-2">
            <div class="flex items-center gap-4 text-xs text-foreground/40 font-medium">
              <time datetime={post.date}>{post.date}</time>

              <span>•</span>
              <span>{post.readingTime} read</span>
            </div>
            <h2 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors">
              <a href="#">{post.title}</a>
            </h2>
            <p class="text-sm text-foreground/60 leading-relaxed max-w-2xl">
              {post.excerpt}
            </p>
          </article>
        ))}
      </section>
    </main>

    <Footer />
	</body>
</html>
