---
import '../styles/globals.css';
import '@fontsource-variable/geist';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ArrowRight, CodeXml, Newspaper, User } from 'lucide-react';

const title = "rockyxwall | Tech Hobbyist & Developer";
const description = "Portfolio of rockyxwall, a student and tech hobbyist learning web development.";
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <meta name="description" content={description} />
	</head>
	<body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 container max-w-screen-md mx-auto px-4 py-24 md:py-32 space-y-32">
      <!-- Minimal Hero -->
      <section class="space-y-6 text-center">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight">
          Learning and building for the <span class="text-primary italic">open web</span>.
        </h1>
        <p class="text-lg text-foreground/60 max-w-xl mx-auto leading-relaxed">
          I'm rockyxwall, a student and tech hobbyist learning webdev. I enjoy experimenting with new technologies and building useful tools.
        </p>
        <div class="flex items-center justify-center gap-4 pt-4">
          <a href={`${import.meta.env.BASE_URL}/about`} class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
            More about me
          </a>
          <a href={`${import.meta.env.BASE_URL}/projects`} class="inline-flex items-center justify-center rounded-md border border-input bg-background px-6 py-3 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
            View projects
          </a>
        </div>
      </section>

      <!-- Highlights Grid -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href={`${import.meta.env.BASE_URL}/about`} class="group space-y-3 p-6 rounded-2xl border border-border bg-muted/30 hover:bg-muted/50 transition-all">
          <div class="p-2 rounded-lg bg-primary/10 w-fit text-primary">
            <User className="h-6 w-6" />
          </div>
          <h2 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
            My Story <ArrowRight className="h-4 w-4 opacity-0 group-hover:opacity-100 transition-all" />
          </h2>
          <p class="text-sm text-foreground/60">A student's journey into the world of tech and web development.</p>
        </a>

        <a href={`${import.meta.env.BASE_URL}/projects`} class="group space-y-3 p-6 rounded-2xl border border-border bg-muted/30 hover:bg-muted/50 transition-all">
          <div class="p-2 rounded-lg bg-primary/10 w-fit text-primary">
            <CodeXml className="h-6 w-6" />
          </div>
          <h2 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
            Projects <ArrowRight className="h-4 w-4 opacity-0 group-hover:opacity-100 transition-all" />
          </h2>
          <p class="text-sm text-foreground/60">Exploring core JavaScript projects and personalized user scripts.</p>
        </a>

        <a href={`${import.meta.env.BASE_URL}/blog`} class="group space-y-3 p-6 rounded-2xl border border-border bg-muted/30 hover:bg-muted/50 transition-all">
          <div class="p-2 rounded-lg bg-primary/10 w-fit text-primary">
            <Newspaper className="h-6 w-6" />
          </div>
          <h2 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
            Blog <ArrowRight className="h-4 w-4 opacity-0 group-hover:opacity-100 transition-all" />
          </h2>
          <p class="text-sm text-foreground/60">Sharing what I learn as I navigate the ever-changing landscape of tech.</p>
        </a>

      </section>
    </main>

    <Footer />
	</body>
</html>
