---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "404 - Page Not Found | rockyxwall";
---

<BaseLayout title={title}>
    <main class="flex-1 flex flex-col items-center justify-center container max-w-screen-md mx-auto px-4 py-24 text-center space-y-6">
      <h1 class="text-6xl font-bold tracking-tight text-primary">404</h1>
      <h2 class="text-3xl font-bold tracking-tight">Oops! Page not found.</h2>
      <p class="text-lg text-foreground/60 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="pt-4">
        <a href={import.meta.env.BASE_URL} class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
          Back to Home
        </a>
      </div>
    </main>
</BaseLayout>
