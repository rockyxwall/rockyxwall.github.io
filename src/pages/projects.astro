---
import '../styles/globals.css';
import '@fontsource-variable/geist';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ExternalLink, Terminal } from 'lucide-react';

const title = "Projects | rockyxwall";
const description = "A selection of projects I've built or worked on.";

const projects = [
  {
    title: "lazy-study-doc",
    description: "A personal site where I listed some online resources that I used to study for high school.",
    link: "https://github.com/rockyxwall/lazy-study-doc",
    github: "https://github.com/rockyxwall/lazy-study-doc",
    tags: ["HTML", "CSS"]
  },
  {
    title: "js-core-projects",
    description: "All the basic projects I have done to learn the language.",
    link: "https://github.com/rockyxwall/js-core-projects",
    github: "https://github.com/rockyxwall/js-core-projects",
    tags: ["JavaScript"]
  },
  {
    title: "my-user-scripts-and-styles",
    description: "User scripts and styles for personal use.",
    link: "https://github.com/rockyxwall/my-user-scripts-and-styles",
    github: "https://github.com/rockyxwall/my-user-scripts-and-styles",
    tags: ["JavaScript", "CSS"]
  }
];
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <meta name="description" content={description} />
	</head>
	<body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 container max-w-screen-md mx-auto px-4 py-12 md:py-24 space-y-12">
      <section class="space-y-4">
        <h1 class="text-3xl font-bold tracking-tight">Projects</h1>
        <p class="text-foreground/60 leading-relaxed">
          Here are some of the things I've been working on as I learn web development.
        </p>
      </section>

      <section class="grid grid-cols-1 gap-6">
        {projects.map((project) => (
          <div class="group relative overflow-hidden rounded-xl border border-border bg-muted/30 p-6 transition-all hover:bg-muted/50">
            <div class="flex items-start justify-between">
              <div class="space-y-2">
                <h3 class="text-xl font-bold tracking-tight">{project.title}</h3>
                <p class="text-sm text-foreground/60 leading-relaxed">{project.description}</p>
                <div class="flex flex-wrap gap-2 pt-2">
                  {project.tags.map(tag => (
                    <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <div class="flex gap-2">
                <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-foreground/40 hover:text-foreground transition-colors">
                  <Terminal className="h-5 w-5" />
                </a>
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-foreground/40 hover:text-foreground transition-colors">
                  <ExternalLink className="h-5 w-5" />
                </a>
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

    <Footer />
	</body>
</html>
