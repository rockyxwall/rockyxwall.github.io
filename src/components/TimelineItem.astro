---
interface Props {
  date: string;
  image?: string;
}

const { date, image } = Astro.props;
---

<div class="relative pl-8 pb-12 last:pb-0">
  <div class="timeline-line"></div>
  <div class="timeline-dot -left-[1px] top-1"></div>
  
  <div class="space-y-4">
    <time class="text-xs font-semibold text-primary uppercase tracking-wider">{date}</time>
    
    {image && (
      <div class="overflow-hidden rounded-xl border border-border bg-muted shadow-lg">
        <img src={image.startsWith('http') ? image : `${import.meta.env.BASE_URL}${image}`} alt={date} class="w-full h-auto object-cover" />
      </div>
    )}

    
    <div class="prose prose-invert prose-sm max-w-none text-foreground/80 leading-relaxed">
      <slot />
    </div>
  </div>
</div>
